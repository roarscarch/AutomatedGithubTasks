{
  "current_project": {
    "name": "git-graph-mtime",
    "description": "Visualize the real-world time your Git branches spent diverged as an interactive force-directed graph, revealing hidden merge delays and parallel work bottlenecks.",
    "tagline": "See time lost in branches.",
    "language": "typescript",
    "stack": [
      "cytoscape.js",
      "nodegit"
    ],
    "features": [
      "Parses commit timestamps from local Git history via nodegit",
      "Computes elapsed wall-clock time between branch creation and merge",
      "Renders an interactive force-directed graph with edge thickness proportional to divergence time",
      "Highlights branches with the longest absolute drift",
      "Exports graph as SVG or PNG for reports"
    ],
    "architecture_note": "Uses a two-pass algorithm: first builds a commit DAG with timestamps, then runs a custom cost function that maps merge intervals to edge weights for Cytoscape.js layout using an inverted spring model."
  },
